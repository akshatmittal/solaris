{
  "name": "rainbowkit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @rainbow-me/rainbowkit dev",
    "build": "pnpm --filter @rainbow-me/rainbowkit build",
    "start": "pnpm dev",
    "lint": "biome lint . && pnpm format:check && pnpm --recursive typecheck",
    "lint:fix": "biome lint . --write && pnpm format:fix",
    "format:check": "biome check .",
    "format:fix": "biome format . --write",
    "test": "pnpm test:unit",
    "test:unit": "vitest",
    "test:update": "vitest --update",
    "test:watch": "vitest --watch",
    "changeset": "changeset",
    "clean": "rm -rf ./packages/rainbowkit/dist && rm -rf ./packages/rainbowkit/node_modules && pnpm install",
    "clean:untracked": "git clean -fxd -e '.env.local' -e '.env' && pnpm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rainbow-me/rainbowkit.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@changesets/cli": "2.29.4",
    "@tanstack/react-query": "^5.55.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/esbuild-plugin": "^2.3.21",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.5",
    "esbuild-plugin-replace": "^1.4.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.5",
    "postcss-prefix-selector": "^2.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recursive-readdir-files": "^2.3.1",
    "typescript": "5.5.4",
    "viem": "2.38.0",
    "vite": "^7.3.0",
    "vitest": "2.1.9",
    "wagmi": "^2.19.3"
  },
  "resolutions": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "elliptic": "6.6.1"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=24"
  }
}
