{
  "name": "solaris-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "build:lib": "turbo run build --filter=solariskit",
    "changeset": "changeset",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "dev": "turbo dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix --fix-suggestions --fix-dangerously",
    "release": "changeset publish",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "taze": "^19.14.1",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.2"
}
