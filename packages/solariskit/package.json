{
  "name": "solariskit",
  "version": "1.4.0",
  "description": "The best way to connect a wallet",
  "keywords": [
    "blockchain",
    "ens",
    "ethereum",
    "hooks",
    "react",
    "react-hook"
  ],
  "license": "MIT",
  "author": "Rainbow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akshatmittal/solaris.git",
    "directory": "packages/solariskit"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "src/css/reset.css.ts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./styles.css": "./dist/index.css",
    "./solana": {
      "types": "./dist/solana/index.d.ts",
      "import": "./dist/solana/index.js"
    },
    "./solana/styles.css": "./dist/index.css",
    "./wallets": "./dist/wallets/walletConnectors/index.js",
    "./components": "./dist/components/index.js"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "rm -rf .turbo dist node_modules",
    "dev": "pnpm run build:watch",
    "prepack": "pnpm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "pnpm tsc --noEmit",
    "typegen": "tsc --emitDeclarationOnly",
    "typegen:watch": "tsc --emitDeclarationOnly --watch"
  },
  "dependencies": {
    "@akshatmittal/polycons": "workspace:*",
    "@solana/connector": "^0.2.4",
    "@solana/kit": "^5.5.1",
    "@vanilla-extract/css": "1.20.1",
    "@vanilla-extract/dynamic": "2.1.5",
    "@vanilla-extract/sprinkles": "1.6.5",
    "clsx": "2.1.1",
    "cuer": "0.0.3",
    "qr": "0.5.5",
    "react-remove-scroll": "2.7.2"
  },
  "devDependencies": {
    "@base-org/account": "^2.5.7",
    "@rollup/plugin-replace": "^6.0.3",
    "@safe-global/safe-apps-provider": "^0.18.6",
    "@safe-global/safe-apps-sdk": "^9.1.0",
    "@tanstack/react-query": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/postcss-prefix-selector": "^1.16.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vanilla-extract/css-utils": "0.1.6",
    "@vanilla-extract/private": "1.0.9",
    "@vanilla-extract/rollup-plugin": "^1.5.3",
    "@vanilla-extract/vite-plugin": "catalog:",
    "@walletconnect/ethereum-provider": "^2.23.10",
    "@workspace/typescript-config": "workspace:*",
    "autoprefixer": "catalog:",
    "jsdom": "catalog:",
    "msw": "^2.14.6",
    "nock": "^14.0.16",
    "postcss": "catalog:",
    "postcss-prefix-selector": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wagmi": "catalog:"
  },
  "peerDependencies": {
    "@base-org/account": "^2.5.1",
    "@safe-global/safe-apps-provider": "^0.18.6",
    "@safe-global/safe-apps-sdk": "^9.1.0",
    "@tanstack/react-query": ">=5.0.0",
    "@walletconnect/ethereum-provider": "^2.21.1",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "viem": "^2.0.0",
    "wagmi": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@base-org/account": {
      "optional": true
    },
    "@safe-global/safe-apps-provider": {
      "optional": true
    },
    "@safe-global/safe-apps-sdk": {
      "optional": true
    },
    "@walletconnect/ethereum-provider": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  }
}
