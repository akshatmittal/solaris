{
  "name": "solariskit",
  "version": "1.0.0",
  "description": "The best way to connect a wallet",
  "keywords": [
    "blockchain",
    "ens",
    "ethereum",
    "hooks",
    "react",
    "react-hook"
  ],
  "license": "MIT",
  "author": "Rainbow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akshatmittal/solaris.git",
    "directory": "packages/solariskit"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "src/css/reset.css.ts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./styles.css": "./dist/index.css",
    "./wallets": "./dist/wallets/walletConnectors/index.js"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "rm -rf .turbo dist node_modules",
    "dev": "pnpm run build:watch",
    "prepack": "MINIFY_CSS=true pnpm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "pnpm tsc --noEmit",
    "typegen": "tsc --emitDeclarationOnly",
    "typegen:watch": "tsc --emitDeclarationOnly --watch"
  },
  "dependencies": {
    "@vanilla-extract/css": "1.18.0",
    "@vanilla-extract/dynamic": "2.1.5",
    "@vanilla-extract/sprinkles": "1.6.5",
    "clsx": "2.1.1",
    "cuer": "0.0.3",
    "react-remove-scroll": "2.6.2",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@tanstack/react-query": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/postcss-prefix-selector": "^1.16.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/ua-parser-js": "^0.7.39",
    "@vanilla-extract/css-utils": "0.1.6",
    "@vanilla-extract/private": "1.0.9",
    "@vanilla-extract/rollup-plugin": "^1.5.3",
    "@vanilla-extract/vite-plugin": "catalog:",
    "@workspace/typescript-config": "workspace:*",
    "autoprefixer": "catalog:",
    "jsdom": "catalog:",
    "msw": "^2.13.1",
    "nock": "^14.0.12",
    "postcss": "catalog:",
    "postcss-prefix-selector": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "^0.21.7",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wagmi": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18",
    "react-dom": ">=18",
    "viem": "2.x",
    "wagmi": "^2.9.0"
  },
  "engines": {
    "node": ">=12.4"
  }
}
