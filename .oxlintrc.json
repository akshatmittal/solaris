{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "react", "react-perf"],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/.pnpm-store/**",
    "**/.output/**",
    "**/.tanstack/**",
    "**/.conductor/**",
    "pnpm-lock.yaml"
  ],
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}
